# ─────────────────────────────────────────────────────────────
# SHANTI ESSENCE — variables de entorno
# Copia este archivo a .env.local y llena los valores.
# .env.local JAMÁS se sube a git (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# Stripe — llave PÚBLICA (sí puede ir al navegador, prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe — llave SECRETA. SOLO servidor (lib/stripe.ts y rutas api/).
# NUNCA con prefijo NEXT_PUBLIC_, NUNCA en componentes de cliente.
STRIPE_SECRET_KEY=

# Stripe — secreto para verificar la firma del webhook.
# Lo da `stripe listen` en local o el dashboard en producción.
STRIPE_WEBHOOK_SECRET=

# URL pública del sitio (para redirects de Stripe Checkout).
# Local: http://localhost:3000 — Producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
